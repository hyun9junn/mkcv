% =============================================================
% MKCV — Template: banking
% Audience: finance / consulting / law
% Compiler: pdfLaTeX
% Layout: single column, ModernCV banking-inspired, tabular date entries
% Packages: array, tabularx, microtype
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=15mm,bottom=15mm,left=17mm,right=17mm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{microtype}
\usepackage{array}
\usepackage{tabularx}

% ---------- palette ------------------------------------------
\definecolor{cvaccent}{HTML}{1e3a5f}
\definecolor{cvink}{HTML}{111827}
\definecolor{cvrule}{HTML}{1e3a5f}
\definecolor{cvmute}{HTML}{6b7280}

% ---------- date column width --------------------------------
\newlength{\dateW}
\setlength{\dateW}{2.6cm}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

% ---------- commands -----------------------------------------
\newcommand{\cvrole}[1]{{\bfseries\color{cvink} #1}}
\newcommand{\cvorg}[1]{{\itshape\color{cvmute} #1}}
\newcommand{\cvdate}[1]{{\small\color{cvmute} #1}}

\newcommand{\mainsection}[1]{%
  \vspace{10pt}%
  {\color{cvaccent}\bfseries\MakeUppercase{#1}}%
  \par\vspace{1pt}%
  {\color{cvrule}\rule{\linewidth}{1pt}}%
  \par\vspace{5pt}%
}

\newenvironment{cvitems}{%
  \begin{itemize}[leftmargin=1em,labelsep=0.4em,itemsep=0.5pt,topsep=\cvitembefore,parsep=0pt,label=\textendash]%
}{\end{itemize}}

% tabular entry: date | content
\newcommand{\cventry}[2]{%
  \begin{tabular}{@{}p{\dateW}@{\hspace{4pt}}p{\dimexpr\linewidth-\dateW-4pt\relax}@{}}%
    \cvdate{#1} & #2%
  \end{tabular}\par%
}

\begin{document}

% =========================
% HEADER
% =========================
\noindent
\begin{minipage}[t]{0.55\linewidth}
  {\LARGE\bfseries\color{cvaccent} << cv.personal.name >>}\\[4pt]
  <% if cv.personal.tagline %>{\normalsize\color{cvmute}\itshape << cv.personal.tagline >>}<% endif %>
\end{minipage}%
\hfill
\begin{minipage}[t]{0.42\linewidth}
  \raggedleft
  <% if cv.personal.email %>{\small\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}}\\<% endif %>
  <% if cv.personal.phone %>{\small << cv.personal.phone >>}\\<% endif %>
  <% if cv.personal.location %>{\small << cv.personal.location >>}\\<% endif %>
  <% if cv.personal.linkedin %>{\small\href{https://<< cv.personal.linkedin >>}{LinkedIn}}\\<% endif %>
  <% if cv.personal.github %>{\small\href{https://<< cv.personal.github >>}{GitHub (<< cv.personal.github.rstrip('/').split('/')[-1] >>)}}\\<% endif %>
  <% if cv.personal.huggingface %>{\small\href{https://<< cv.personal.huggingface >>}{Hugging Face}}\\<% endif %>
\end{minipage}
\vspace{4pt}
{\color{cvaccent}\rule{\linewidth}{1.5pt}}

<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\mainsection{Summary}
<< cv.summary >>
<% endif %>

<% if key == 'experience' and cv.experience %>
\mainsection{Experience}
<% for job in cv.experience %>
\cventry{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}{%
  {<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}}, \cvorg{<< job.company >>}<% if job.location %> \hfill \cvdate{<< job.location >>}<% endif %>
  <% if job.highlights %>
  \begin{cvitems}
  <% for item in job.highlights %>
    \item << item >>
  <% endfor %>
  \end{cvitems}
  <% endif %>
}
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\mainsection{Education}
<% for edu in cv.education %>
\cventry{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}{%
  {<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}}, \cvorg{<< edu.institution >>}<% if edu.gpa %> \hfill \cvdate{GPA: << edu.gpa >>}<% endif %>
}
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\mainsection{Skills}
<% for group in cv.skills %>
\cventry{\cvdate{<< group.category >>}}{<< group.items | join(", ") >>}
<% endfor %>
<% endif %>

<% if key == 'projects' and cv.projects %>
\mainsection{Projects}
<% for proj in cv.projects %>
\cventry{<% if proj.date %><< proj.date >><% endif %>}{%
  {<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} --- \cvorg{<< proj.description >>}
  <% if proj.highlights %>
  \begin{cvitems}
  <% for item in proj.highlights %>
    \item << item >>
  <% endfor %>
  \end{cvitems}
  <% endif %>
}
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\mainsection{Publications}
\begin{enumerate}[leftmargin=1.5em,itemsep=3pt,topsep=\cvitembefore,label=\textup{[\arabic*]}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textbf{<< pub.title >>}}<% else %>\textbf{<< pub.title >>}<% endif %>.<% if pub.authors %> << pub.authors | join(", ") >>.<% endif %><% if pub.venue %> \textit{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{enumerate}
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\mainsection{Certifications}
<% for cert in cv.certifications %>
\cventry{<% if cert.date %><< cert.date >><% endif %>}{%
  \cvrole{<< cert.name >>}<% if cert.issuer %>, \cvorg{<< cert.issuer >>}<% endif %>
}
<% endfor %>
<% endif %>

<% if key == 'awards' and cv.awards %>
\mainsection{Awards}
<% for award in cv.awards %>
\cventry{<% if award.date %><< award.date >><% endif %>}{%
  \cvrole{<< award.name >>}<% if award.issuer %>, \cvorg{<< award.issuer >>}<% endif %>
  <% if award.description %>\\{\small << award.description >>}<% endif %>
}
<% endfor %>
<% endif %>

<% if key == 'languages' and cv.languages %>
\mainsection{Languages}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~<< lang.proficiency >><% if not loop.last %>\quad\textperiodcentered\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\mainsection{Activities}
<% for act in cv.extracurricular %>
\cventry{<% if act.date %><< act.date >><% endif %>}{%
  \cvrole{<< act.title >>}<% if act.organization %>, \cvorg{<< act.organization >>}<% endif %>
  <% if act.highlights %>
  \begin{cvitems}
  <% for item in act.highlights %>
    \item << item >>
  <% endfor %>
  \end{cvitems}
  <% endif %>
}
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\mainsection{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}

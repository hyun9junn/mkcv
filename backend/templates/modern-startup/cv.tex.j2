% =============================================================
% MKCV — Template: modern-startup
% Drop-in replacement for cv.tex.j2
% Audience: SWE / AI engineers / startup candidates
% Compiler: pdfLaTeX (XeLaTeX also works)
% Page: A4, airy, ink-only, EB Garamond display + sans body
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=2.0cm,bottom=2.0cm,left=2.1cm,right=2.1cm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{ebgaramond}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{titling}
\usepackage{microtype}
\usepackage{array}
\usepackage{parskip}
\usepackage{etoolbox}

% ---------- palette (ink-only) --------------------------------
\definecolor{cvink}{HTML}{0A0A0A}
\definecolor{cvmute}{HTML}{6B6B6B}
\definecolor{cvrule}{HTML}{D9D6D0}

\color{cvink}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}
\pagestyle{empty}
\linespread{1.08}

% ---------- section: sans-y uppercase, hairline rule ----------
\titleformat{\section}
  {\normalsize\bfseries\sffamily}
  {}{0em}
  {\MakeUppercase}
  [\vspace{1pt}{\color{cvrule}\titlerule[0.4pt]}]
\titlespacing*{\section}{0pt}{\cvsecbefore}{\cvsecafter}

% ---------- local helpers ------------------------------------
\newcommand{\cvrole}[1]{{\bfseries\sffamily #1}}
\newcommand{\cvorg}[1]{{\sffamily\color{cvmute}\small #1}}
\newcommand{\cvdate}[1]{{\sffamily\color{cvmute}\small #1}}

\newenvironment{cvitems}
  {\begin{itemize}[leftmargin=1.1em,labelsep=0.5em,itemsep=1pt,topsep=\cvitembefore,parsep=0pt,label=\textendash]}
  {\end{itemize}}

\begin{document}

% =========================
% Header
% =========================
\begin{center}
    {\ebgaramond<< cv.personal.name | name_fontsize(26, 1.15) >> << cv.personal.name >>}\\[6pt]

    {\sffamily\small\color{cvmute}
    <% set sep = joiner(" \,\textperiodcentered\, ") %>
    <% if cv.personal.email %><< sep() >>\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}<% endif %>
    <% if cv.personal.phone %><< sep() >><< cv.personal.phone >><% endif %>
    <% if cv.personal.location %><< sep() >><< cv.personal.location >><% endif %>
    }\\[3pt]

    {\sffamily\small\color{cvmute}
    <% set sep2 = joiner(" \,\textperiodcentered\, ") %>
    <% if cv.personal.github %><< sep2() >>\href{https://<< cv.personal.github >>}{<< cv.personal.github >>}<% endif %>
    <% if cv.personal.linkedin %><< sep2() >>\href{https://<< cv.personal.linkedin >>}{LinkedIn}<% endif %>
    <% if cv.personal.huggingface %><< sep2() >>\href{https://<< cv.personal.huggingface >>}{Hugging Face}<% endif %>
    <% if cv.personal.website %><< sep2() >>\href{https://<< cv.personal.website >>}{Website}<% endif %>
    }
\end{center}

% =========================
% Sections
% =========================
<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\section{Summary}
<< cv.summary >>
<% endif %>

<% if key == 'experience' and cv.experience %>
\section{Experience}
<% for job in cv.experience %>
{<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}} \hfill \cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}\\
\cvorg{<< job.company >>}
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{Education}
<% for edu in cv.education %>
{<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}} \hfill \cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}\\
\cvorg{<< edu.institution >>}<% if edu.gpa %> \hfill \cvdate{GPA: << edu.gpa >>}<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{Skills}
\begin{tabular}{@{}p{0.20\textwidth}@{\hspace{6pt}}p{0.76\textwidth}@{}}
<% for group in cv.skills %>
\cvrole{<< group.category >>} & << group.items | join(" \,\textperiodcentered\, ") >> \\[2pt]
<% endfor %>
\end{tabular}
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{Projects}
<% for proj in cv.projects %>
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} \hfill \cvdate{<% if proj.url %><< proj.url >><% endif %>}\\
\cvorg{\itshape << proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{Certifications}
<% for cert in cv.certifications %>
\cvrole{<< cert.name >>}<% if cert.issuer %> --- \cvorg{<< cert.issuer >>}<% endif %><% if cert.date %> \hfill \cvdate{<< cert.date >>}<% endif %>\\
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{Publications}
\begin{itemize}[leftmargin=1.2em,itemsep=3pt,topsep=\cvitembefore]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textbf{<< pub.title >>}}<% else %>\textbf{<< pub.title >>}<% endif %><% if pub.venue %>, \textit{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{Languages}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~<< lang.proficiency >><% if not loop.last %>\quad\textperiodcentered\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{Awards}
<% for award in cv.awards %>
\cvrole{<< award.name >>}<% if award.date %> \hfill \cvdate{<< award.date >>}<% endif %>\\
<% if award.issuer %>\cvorg{<< award.issuer >>}\\<% endif %>
<% if award.description %><< award.description >>\\<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{Activities}
<% for act in cv.extracurricular %>
\cvrole{<< act.title >>}<% if act.date %> \hfill \cvdate{<< act.date >>}<% endif %>\\
<% if act.organization %>\cvorg{<< act.organization >>}\\<% endif %>
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}

% =============================================================
% MKCV — Template: hipster
% Audience: creative / design / UX / startup
% Compiler: pdfLaTeX
% Layout: dark sidebar (28%) + white main (70%), colorbox section headers
% Packages: paracol, eso-pic, tikz, graphicx
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=16mm,bottom=15mm,left=0pt,right=15mm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{microtype}
\usepackage{eso-pic}
\usepackage{paracol}
\usepackage{tikz}
\usepackage{graphicx}

% ---------- palette ------------------------------------------
\definecolor{cvside}{HTML}{2d3250}
\definecolor{cvaccent}{HTML}{2EB6E1}
\definecolor{cvsidetext}{HTML}{e8eaf0}
\definecolor{cvsidemute}{HTML}{8fa3b1}
\definecolor{cvink}{HTML}{111827}
\definecolor{cvrule}{HTML}{d1d5db}

% ---------- sidebar dimensions -------------------------------
\newlength{\sidebarW}
\setlength{\sidebarW}{0.28\textwidth}
\newlength{\sidebarPadL}
\setlength{\sidebarPadL}{9mm}
\newlength{\sidebarPadR}
\setlength{\sidebarPadR}{7mm}
\newlength{\mainGap}
\setlength{\mainGap}{9mm}

\AddToShipoutPictureBG{%
  \AtPageLowerLeft{%
    {\color{cvside}\rule{\sidebarW}{\paperheight}}%
  }%
}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}
\setlength{\columnsep}{0pt}

% ---------- commands -----------------------------------------
\newcommand{\cvrole}[1]{{\bfseries #1}}
\newcommand{\cvorg}[1]{{\itshape\color{gray} #1}}
\newcommand{\cvdate}[1]{{\small\color{gray} #1}}

% Colorbox section header for main column
\newcommand{\mainsection}[1]{%
  \vspace{8pt}%
  \noindent\colorbox{cvaccent}{\parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
    \footnotesize\bfseries\sffamily\color{white}\MakeUppercase{#1}%
  }}%
  \par\vspace{4pt}%
}

% Plain section for sidebar
\newcommand{\sidesection}[1]{%
  \vspace{8pt}%
  {\footnotesize\bfseries\sffamily\color{cvaccent}\MakeUppercase{#1}}%
  \par\vspace{1pt}%
  {\color{cvaccent!50}\rule{\linewidth}{0.5pt}}%
  \par\vspace{4pt}%
}

\newenvironment{cvitems}{%
  \begin{itemize}[leftmargin=1em,labelsep=0.4em,itemsep=0.5pt,topsep=\cvitembefore,parsep=0pt,label=\textendash]%
}{\end{itemize}}

\begin{document}
\columnratio{0.28}
\begin{paracol}{2}

% =========================
% LEFT — Sidebar
% =========================
\hspace{\sidebarPadL}%
\begin{minipage}[t]{\dimexpr\sidebarW-\sidebarPadL-\sidebarPadR\relax}
\color{cvsidetext}

% Photo (optional)
<% if cv.personal.photo %>
\begin{center}
\begin{tikzpicture}
  \clip (0,0) circle (1.0cm);
  \node at (0,0) {\includegraphics[width=2.0cm,height=2.0cm,keepaspectratio]{<< cv.personal.photo >>}};
\end{tikzpicture}
\end{center}
\vspace{4pt}
<% endif %>

{\large\bfseries\sffamily\color{white}\raggedright << cv.personal.name >>}
\vspace{3pt}\par

<% if cv.personal.tagline %>
{\footnotesize\color{cvsidemute}\itshape << cv.personal.tagline >>}
\vspace{6pt}\par
<% endif %>

{\color{cvaccent}\rule{\linewidth}{1.5pt}}
\vspace{6pt}

<% if cv.personal.email %>
{\footnotesize\color{cvsidemute}\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}}\\[3pt]
<% endif %>
<% if cv.personal.phone %>
{\footnotesize\color{cvsidemute} << cv.personal.phone >>}\\[3pt]
<% endif %>
<% if cv.personal.location %>
{\footnotesize\color{cvsidemute} << cv.personal.location >>}\\[3pt]
<% endif %>
<% if cv.personal.github %>
{\footnotesize\color{cvsidemute}\href{https://<< cv.personal.github >>}{GitHub (<< cv.personal.github.rstrip('/').split('/')[-1] >>)}}\\[3pt]
<% endif %>
<% if cv.personal.linkedin %>
{\footnotesize\color{cvsidemute}\href{https://<< cv.personal.linkedin >>}{LinkedIn}}\\[3pt]
<% endif %>
<% if cv.personal.huggingface %>
{\footnotesize\color{cvsidemute}\href{https://<< cv.personal.huggingface >>}{Hugging Face}}\\[3pt]
<% endif %>
<% if cv.personal.website %>
{\footnotesize\color{cvsidemute}\href{https://<< cv.personal.website >>}{<< cv.personal.website >>}}\\[3pt]
<% endif %>

<% if cv.skills %>
\sidesection{Skills}
<% for group in cv.skills %>
{\footnotesize\bfseries\color{white} << group.category >>}\\[1pt]
{\footnotesize\color{cvsidemute} << group.items | join(", ") >>}\\[5pt]
<% endfor %>
<% endif %>

<% if cv.languages %>
\sidesection{Languages}
<% for lang in cv.languages %>
{\footnotesize\color{cvsidetext} \textbf{<< lang.language >>}~--~<< lang.proficiency >>}\\[3pt]
<% endfor %>
<% endif %>

\end{minipage}

\switchcolumn

% =========================
% RIGHT — Main content
% =========================
\hspace{\mainGap}%
\begin{minipage}[t]{\dimexpr\linewidth-\mainGap\relax}
\color{cvink}

<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\mainsection{Summary}
<< cv.summary >>
<% endif %>

<% if key == 'experience' and cv.experience %>
\mainsection{Experience}
<% for job in cv.experience %>
{<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}} \hfill \cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}\\
\cvorg{<< job.company >>}<% if job.location %>, << job.location >><% endif %>
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\mainsection{Education}
<% for edu in cv.education %>
{<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}} \hfill \cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}\\
\cvorg{<< edu.institution >>}<% if edu.gpa %> \hfill \cvdate{GPA: << edu.gpa >>}<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'projects' and cv.projects %>
\mainsection{Projects}
<% for proj in cv.projects %>
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} --- \cvorg{<< proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\mainsection{Publications}
\begin{enumerate}[leftmargin=1.5em,itemsep=3pt,topsep=\cvitembefore,label=\textup{[\arabic*]}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textbf{<< pub.title >>}}<% else %>\textbf{<< pub.title >>}<% endif %>.<% if pub.authors %> << pub.authors | join(", ") >>.<% endif %><% if pub.venue %> \textit{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{enumerate}
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\mainsection{Certifications}
<% for cert in cv.certifications %>
\cvrole{<< cert.name >>}<% if cert.issuer %>, \cvorg{<< cert.issuer >>}<% endif %><% if cert.date %> \hfill \cvdate{<< cert.date >>}<% endif %>\\
<% endfor %>
<% endif %>

<% if key == 'awards' and cv.awards %>
\mainsection{Awards}
<% for award in cv.awards %>
\cvrole{<< award.name >>}<% if award.issuer %>, \cvorg{<< award.issuer >>}<% endif %><% if award.date %> \hfill \cvdate{<< award.date >>}<% endif %>\\
<% if award.description %>{\small << award.description >>}\\<% endif %>
<% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\mainsection{Activities}
<% for act in cv.extracurricular %>
\cvrole{<< act.title >>}<% if act.date %> \hfill \cvdate{<< act.date >>}<% endif %>\\
<% if act.organization %>\cvorg{<< act.organization >>}\\<% endif %>
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\mainsection{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{minipage}

\end{paracol}
\end{document}

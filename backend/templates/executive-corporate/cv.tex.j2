% =============================================================
% MKCV — Template: executive-corporate
% Drop-in replacement for cv.tex.j2
% Audience: consulting / finance / corporate / senior IC
% Compiler: pdfLaTeX
% Page: A4, dense, Libertine serif, burgundy accent, flush header
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=1.7cm,bottom=1.7cm,left=1.8cm,right=1.8cm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{libertine}
\usepackage[scale=0.92]{tgheros}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{microtype}
\usepackage{array}
\usepackage{parskip}
\usepackage{etoolbox}

% ---------- palette ------------------------------------------
\definecolor{cvink}{HTML}{111214}
\definecolor{cvmute}{HTML}{5B5F66}
\definecolor{cvaccent}{HTML}{7F1D1D}     % burgundy

\color{cvink}
\setlength{\parindent}{0pt}
\setlength{\parskip}{2.5pt}
\pagestyle{empty}
\linespread{1.03}

% ---------- section: small burgundy square + uppercase -------
\titleformat{\section}
  {\small\bfseries\sffamily}
  {\textcolor{cvaccent}{\rule[0.1ex]{0.45em}{0.45em}}\hspace{0.5em}}
  {0em}
  {\MakeUppercase}
  [\vspace{1.5pt}{\color{cvink}\titlerule[0.4pt]}]
\titlespacing*{\section}{0pt}{\cvsecbefore}{\cvsecafter}

\newcommand{\cvrole}[1]{{\bfseries #1}}
\newcommand{\cvorg}[1]{{\itshape\color{cvmute}#1}}
\newcommand{\cvdate}[1]{{\sffamily\footnotesize\color{cvmute}#1}}

\newenvironment{cvitems}
  {\begin{itemize}[leftmargin=1.0em,labelsep=0.4em,itemsep=1pt,topsep=\cvitembefore,parsep=0pt]}
  {\end{itemize}}

\begin{document}

% =========================
% Header — flush two-column
% =========================
\begin{minipage}[t]{0.62\textwidth}
    {<< cv.personal.name | name_fontsize(22, 1.09) >> << cv.personal.name >>}\\[2pt]
    <% if cv.summary %>{\itshape\color{cvmute}\small << cv.summary.split('.')[0] | trim >>.}<% endif %>
\end{minipage}\hfill
\begin{minipage}[t]{0.36\textwidth}\raggedleft\sffamily\footnotesize\color{cvmute}
    <% if cv.personal.email %>\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}\\<% endif %>
    <% if cv.personal.phone %><< cv.personal.phone >>\\<% endif %>
    <% if cv.personal.location %><< cv.personal.location >>\\<% endif %>
    <% if cv.personal.github %>\href{https://<< cv.personal.github >>}{<< cv.personal.github >>}\\<% endif %>
    <% if cv.personal.linkedin %>\href{https://<< cv.personal.linkedin >>}{<< cv.personal.linkedin >>}\\<% endif %>
    <% if cv.personal.huggingface %>\href{https://<< cv.personal.huggingface >>}{<< cv.personal.huggingface >>}\\<% endif %>
    <% if cv.personal.website %>\href{https://<< cv.personal.website >>}{<< cv.personal.website >>}<% endif %>
\end{minipage}\par\vspace{4pt}
{\color{cvink}\hrule height 0.6pt}

% =========================
% Sections
% =========================
<% macro render_section(key) %>
<#
  Summary first sentence already appears in the header minipage as a tagline.
  Skip the section to avoid duplication.
#>

<% if key == 'experience' and cv.experience %>
\section{Experience}
<% for job in cv.experience %>
{<< job.title | shrink_if_long(40) >>\cvrole{<< job.title >>}} --- \cvorg{<< job.company >>} \hfill \cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{Education}
<% for edu in cv.education %>
{<< edu.degree | shrink_if_long(40) >>\cvrole{<< edu.degree >>}} --- \cvorg{<< edu.institution >>} \hfill \cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}<% if edu.gpa %> \quad GPA: << edu.gpa >><% endif %>\\
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{Skills}
\begin{tabular}{@{}p{0.17\textwidth}@{\hspace{6pt}}p{0.79\textwidth}@{}}
<% for group in cv.skills %>
\cvrole{<< group.category >>} & << group.items | join(" \,\textperiodcentered\, ") >> \\[1.5pt]
<% endfor %>
\end{tabular}
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{Selected Projects}
<% for proj in cv.projects %>
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} --- \cvorg{<< proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{Publications}
\begin{itemize}[leftmargin=1.1em,itemsep=2pt,topsep=\cvitembefore]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textbf{<< pub.title >>}}<% else %>\textbf{<< pub.title >>}<% endif %><% if pub.venue %>, \textit{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{Certifications}
\begin{itemize}[leftmargin=1.1em,itemsep=1.5pt,topsep=\cvitembefore]
<% for cert in cv.certifications %>
  \item \cvrole{<< cert.name >>}<% if cert.issuer %>, << cert.issuer >><% endif %><% if cert.date %> \hfill \cvdate{<< cert.date >>}<% endif %>
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{Awards}
\begin{itemize}[leftmargin=1.1em,itemsep=1.5pt,topsep=\cvitembefore]
<% for award in cv.awards %>
  \item \cvrole{<< award.name >>}<% if award.issuer %>, \cvorg{<< award.issuer >>}<% endif %><% if award.date %> \hfill \cvdate{<< award.date >>}<% endif %>
  <% if award.description %>\\{\small << award.description >>}<% endif %>
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{Languages}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~<< lang.proficiency >><% if not loop.last %>\quad\textperiodcentered\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{Activities}
<% for act in cv.extracurricular %>
\cvrole{<< act.title >>}<% if act.organization %> --- \cvorg{<< act.organization >>}<% endif %><% if act.date %> \hfill \cvdate{<< act.date >>}<% endif %>
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}

% =============================================================
% MKCV — Template: resume-tech
% Audience: software engineers / ATS-friendly single-column
% Compiler: pdfLaTeX
% Layout: single column, bold section headers + full-width rule
% Packages: titlesec, enumitem, microtype
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=11mm,bottom=11mm,left=14mm,right=14mm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{microtype}
\usepackage{titlesec}

\definecolor{cvink}{HTML}{111111}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

% ---------- section heading ----------------------------------
\titleformat{\section}
  {\vspace{6pt}\bfseries\MakeUppercase}
  {}{0pt}{}
  [\vspace{-4pt}\rule{\linewidth}{0.8pt}\vspace{2pt}]

% ---------- commands -----------------------------------------
\newcommand{\cvrole}[1]{{\bfseries #1}}
\newcommand{\cvorg}[1]{{\itshape #1}}
\newcommand{\cvdate}[1]{{\small #1}}

\newenvironment{cvitems}{%
  \begin{itemize}[leftmargin=1.2em,labelsep=0.4em,itemsep=0pt,topsep=\cvitembefore,parsep=0pt,label=\textbullet]%
}{\end{itemize}}

\begin{document}

% =========================
% HEADER
% =========================
{\centering
{<< cv.personal.name | name_size >> << cv.personal.name >>}\\[3pt]
{\small
<% set parts = [] %>
<% if cv.personal.email %><% set parts = parts + [cv.personal.email] %><% endif %>
<% if cv.personal.phone %><% set parts = parts + [cv.personal.phone] %><% endif %>
<% if cv.personal.location %><% set parts = parts + [cv.personal.location] %><% endif %>
<% if cv.personal.linkedin %><% set parts = parts + ['\\href{https://' + cv.personal.linkedin + '}{LinkedIn}'] %><% endif %>
<% if cv.personal.github %><% set parts = parts + ['\\href{https://' + cv.personal.github + '}{GitHub (' + cv.personal.github.rstrip('/').split('/')[-1] + ')}'] %><% endif %>
<% if cv.personal.huggingface %><% set parts = parts + ['\\href{https://' + cv.personal.huggingface + '}{Hugging Face}'] %><% endif %>
<< parts | join(' $|$ ') >>
}
\par}
\vspace{4pt}

<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\section{Summary}
<< cv.summary >>
<% endif %>

<% if key == 'experience' and cv.experience %>
\section{Experience}
<% for job in cv.experience %>
\noindent\cvrole{<< job.company >>} \hfill \cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}\\
{<< job.title | shrink_if_long(48) >>\cvorg{<< job.title >>}}<% if job.location %> \hfill \cvdate{<< job.location >>}<% endif %>
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{Education}
<% for edu in cv.education %>
\noindent\cvrole{<< edu.institution >>} \hfill \cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}\\
{<< edu.degree | shrink_if_long(48) >>\cvorg{<< edu.degree >>}}<% if edu.gpa %> \hfill \cvdate{GPA: << edu.gpa >>}<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{Skills}
<% for group in cv.skills %>
\noindent\cvrole{<< group.category >>:} << group.items | join(", ") >>\\[1pt]
<% endfor %>
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{Projects}
<% for proj in cv.projects %>
\noindent{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} --- \cvorg{<< proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{Publications}
\begin{enumerate}[leftmargin=1.5em,itemsep=2pt,topsep=\cvitembefore,label=\textup{[\arabic*]}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textbf{<< pub.title >>}}<% else %>\textbf{<< pub.title >>}<% endif %>.<% if pub.authors %> << pub.authors | join(", ") >>.<% endif %><% if pub.venue %> \textit{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{enumerate}
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{Certifications}
<% for cert in cv.certifications %>
\noindent\cvrole{<< cert.name >>}<% if cert.issuer %>, \cvorg{<< cert.issuer >>}<% endif %><% if cert.date %> \hfill \cvdate{<< cert.date >>}<% endif %>\\
<% endfor %>
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{Awards}
<% for award in cv.awards %>
\noindent\cvrole{<< award.name >>}<% if award.issuer %>, \cvorg{<< award.issuer >>}<% endif %><% if award.date %> \hfill \cvdate{<< award.date >>}<% endif %>\\
<% if award.description %>{\small << award.description >>}\\<% endif %>
<% endfor %>
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{Languages}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~<< lang.proficiency >><% if not loop.last %>\quad\textperiodcentered\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{Activities}
<% for act in cv.extracurricular %>
\noindent\cvrole{<< act.title >>}<% if act.date %> \hfill \cvdate{<< act.date >>}<% endif %>\\
<% if act.organization %>\cvorg{<< act.organization >>}\\<% endif %>
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
  \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}

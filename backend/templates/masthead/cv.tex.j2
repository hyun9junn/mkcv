% =============================================================
% MKCV — Template: masthead
% Audience: writers / editors / design leads / brand folk
% Compiler: pdfLaTeX
% Layout: oversized serif nameplate, "Issue" dateline, drop-cap
%         summary, two-column body, small-caps section heads
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=18mm,bottom=18mm,left=20mm,right=20mm]{geometry}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{microtype}
<< xelatex_preamble >>
\setmainfont{EB Garamond}
\usepackage{array}
\usepackage{parskip}
\usepackage{etoolbox}
\usepackage{lettrine}
\usepackage{multicol}

% ---------- palette: warm ink + crimson accent ---------------
\definecolor{cvink}{HTML}{1A1613}
\definecolor{cvmute}{HTML}{6E6A65}
\definecolor{cvaccent}{HTML}{8C2A1C}
\definecolor{cvrule}{HTML}{C7BFB3}
\definecolor{cvpaper}{HTML}{FAF7F1}

\pagecolor{cvpaper}
\color{cvink}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}
\setlength{\columnsep}{7mm}
\setlength{\columnseprule}{0pt}
\pagestyle{empty}
\linespread{1.10}

% ---------- section heads: small caps, hairline above + below
\titleformat{\section}
  {\normalsize\bfseries\scshape\color{cvaccent}}
  {}{0em}
  {}
  [\vspace{1pt}{\color{cvrule}\titlerule[0.4pt]}]
\titlespacing*{\section}{0pt}{\cvsecbefore}{\cvsecafter}

% ---------- helper commands ---------------------------------
\newcommand{\cvrole}[1]{{\bfseries #1}}
\newcommand{\cvorg}[1]{{\itshape\color{cvmute} #1}}
\newcommand{\cvdate}[1]{{\sffamily\footnotesize\color{cvmute}\MakeUppercase{#1}}}
\newcommand{\cvkicker}[1]{{\sffamily\scriptsize\color{cvaccent}\MakeUppercase{#1}}}

\newenvironment{cvitems}
  {\begin{itemize}[leftmargin=1.0em,labelsep=0.45em,itemsep=1pt,topsep=\cvitembefore,parsep=0pt,label=\textendash]}
  {\end{itemize}}

\begin{document}

% =========================
% Nameplate / masthead
% =========================
\noindent
{\color{cvrule}\rule{\linewidth}{1.2pt}}\\[2pt]
\noindent
\begin{minipage}[b]{0.55\linewidth}
\raggedright
{\sffamily\footnotesize\color{cvaccent}\MakeUppercase{The Curriculum Vit\ae{}}}\\[2pt]
{<< cv.personal.name | name_fontsize(34, 1.05) >> << cv.personal.name >>}
<% if cv.personal.tagline %>
\\[3pt]{\itshape\color{cvmute} << cv.personal.tagline >>}
<% endif %>
\end{minipage}\hfill
\begin{minipage}[b]{0.40\linewidth}
\raggedleft
{\sffamily\scriptsize\color{cvmute}\MakeUppercase{Issue No. \,I \,\textbullet\, Personal Edition}}\\[2pt]
{\sffamily\footnotesize\color{cvink}
<% set sep = joiner(" \\\\ ") %>
<% if cv.personal.email and contact_visible('email') %><< sep() >>\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}<% endif %>
<% if cv.personal.phone and contact_visible('phone') %><< sep() >><< cv.personal.phone >><% endif %>
<% if cv.personal.location and contact_visible('location') %><< sep() >><< cv.personal.location >><% endif %>
<% if cv.personal.website and contact_visible('website') %><< sep() >>\href{https://<< cv.personal.website >>}{<< link_text(cv.personal.website, 'Website', contact_link_style('website')) >>}<% endif %>
<% if cv.personal.linkedin and contact_visible('linkedin') %><< sep() >>\href{https://<< cv.personal.linkedin >>}{<< link_text(cv.personal.linkedin, 'LinkedIn', contact_link_style('linkedin')) >>}<% endif %>
<% if cv.personal.github and contact_visible('github') %><< sep() >>\href{https://<< cv.personal.github >>}{<< link_text(cv.personal.github, 'GitHub', contact_link_style('github')) >>}<% endif %>
}
\end{minipage}\\[3pt]
{\color{cvrule}\rule{\linewidth}{0.4pt}}\\[1pt]
{\color{cvrule}\rule{\linewidth}{0.4pt}}

\vspace{8pt}

% =========================
% Sections
% =========================
<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\section{<< section_titles.get(key, "Editor's Note") >>}
{\lettrine[lines=2,findent=2pt,nindent=0pt,slope=-2pt]{\color{cvaccent} << cv.summary[0] >>}{}<< cv.summary[1:] >>}
<% endif %>

<% if key == 'experience' and cv.experience %>
\section{<< section_titles.get(key, 'Career') >>}
<% for job in cv.experience %>
\cvkicker{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >><% if job.location %> \,\textbullet\, << job.location >><% endif %>}\\[1pt]
{<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}} \hfill \cvorg{<< job.company >>}
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{<< section_titles.get(key, 'Education') >>}
<% for edu in cv.education %>
\cvkicker{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}\\[1pt]
{<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}} \hfill \cvorg{<< edu.institution >>}
<% if edu.gpa %>\\{\small GPA: << edu.gpa >>}<% endif %>
<% if edu.details %>\\{\small\itshape << edu.details >>}<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{<< section_titles.get(key, 'Skills \& Tooling') >>}
\begin{multicols}{2}
\raggedright
<% for group in cv.skills %>
{\scshape << group.category >>}\\
{\small << group.items | join(", ") >>}\\[3pt]
<% endfor %>
\end{multicols}
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{<< section_titles.get(key, 'Selected Works') >>}
<% for proj in cv.projects %>
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}}<% if proj.date %> \hfill \cvkicker{<< proj.date >>}<% endif %>\\
\cvorg{<< proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{<< section_titles.get(key, 'Bylines \& Publications') >>}
\begin{itemize}[leftmargin=1.2em,itemsep=3pt,topsep=\cvitembefore,label={\color{cvaccent}\textsection}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textit{<< pub.title >>}}<% else %>\textit{<< pub.title >>}<% endif %><% if pub.authors %>. << pub.authors | join(", ") >><% endif %><% if pub.venue %>. \cvorg{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{<< section_titles.get(key, 'Honours') >>}
<% for award in cv.awards %>
\cvrole{<< award.name >>}<% if award.issuer %> --- \cvorg{<< award.issuer >>}<% endif %><% if award.date %> \hfill \cvkicker{<< award.date >>}<% endif %>\\
<% if award.description %>{\small << award.description >>}\\<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{<< section_titles.get(key, 'Certifications') >>}
<% for cert in cv.certifications %>
\cvrole{<< cert.name >>}<% if cert.issuer %> --- \cvorg{<< cert.issuer >>}<% endif %><% if cert.date %> \hfill \cvkicker{<< cert.date >>}<% endif %>\\
<% endfor %>
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{<< section_titles.get(key, 'Languages') >>}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~{\itshape\color{cvmute}<< lang.proficiency >>}<% if not loop.last %>\quad\textbullet\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{<< section_titles.get(key, 'Beyond the Page') >>}
<% for act in cv.extracurricular %>
\cvrole{<< act.title >>}<% if act.organization %> --- \cvorg{<< act.organization >>}<% endif %><% if act.date %> \hfill \cvkicker{<< act.date >>}<% endif %>\\
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}

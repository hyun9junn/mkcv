% =============================================================
% MKCV — Template: gazette
% Audience: classicists / lawyers / writers / academics
% Compiler: pdfLaTeX
% Layout: newspaper nameplate, double rule + dateline,
%         small-caps section heads inline with rules
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=18mm,bottom=18mm,left=22mm,right=22mm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{libertine}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{microtype}
\usepackage{array}
\usepackage{parskip}
\usepackage{etoolbox}

% ---------- palette: ink only, deep aubergine accent ---------
\definecolor{cvink}{HTML}{14110F}
\definecolor{cvmute}{HTML}{6B655F}
\definecolor{cvaccent}{HTML}{4A1E3F}
\definecolor{cvrule}{HTML}{14110F}

\color{cvink}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}
\pagestyle{empty}
\linespread{1.10}

% ---------- gazette section: centered small-caps inside rules
\titleformat{\section}[block]
  {\normalfont}
  {}{0em}
  {\begingroup\centering\scshape\bfseries\color{cvaccent}\MakeLowercase}
  [\endgroup\vspace{1pt}{\color{cvrule}\titlerule[0.4pt]}]
\titlespacing*{\section}{0pt}{\cvsecbefore}{\cvsecafter}

% ---------- helpers ------------------------------------------
\newcommand{\cvrole}[1]{{\bfseries #1}}
\newcommand{\cvorg}[1]{{\itshape #1}}
\newcommand{\cvdate}[1]{{\scshape\footnotesize\color{cvmute} #1}}

\newenvironment{cvitems}
  {\begin{itemize}[leftmargin=1.0em,labelsep=0.4em,itemsep=1pt,topsep=\cvitembefore,parsep=0pt,label=\textemdash]}
  {\end{itemize}}

\begin{document}

% =========================
% Nameplate
% =========================
\noindent
{\color{cvrule}\rule{\linewidth}{1.6pt}}\\[1pt]
{\color{cvrule}\rule{\linewidth}{0.4pt}}\\[2pt]
\begin{center}
{<< cv.personal.name | name_fontsize(36, 1.05) >>\scshape << cv.personal.name >>}
\end{center}
{\color{cvrule}\rule{\linewidth}{0.4pt}}\\[1pt]
\noindent
\begin{minipage}[b]{0.32\linewidth}\raggedright
{\scshape\footnotesize\color{cvmute}Vol. I \,\textbullet\, Curriculum Vit\ae}
\end{minipage}\hfill
\begin{minipage}[b]{0.36\linewidth}\centering
<% if cv.personal.tagline %>{\itshape << cv.personal.tagline >>}<% endif %>
\end{minipage}\hfill
\begin{minipage}[b]{0.30\linewidth}\raggedleft
{\scshape\footnotesize\color{cvmute}
<% if cv.personal.location %><< cv.personal.location >><% endif %>
<% if cv.personal.location and cv.personal.email %> \,\textbullet\, <% endif %>
<% if cv.personal.email %>\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}<% endif %>
}
\end{minipage}\\[1pt]
{\color{cvrule}\rule{\linewidth}{1.6pt}}

\vspace{2pt}
\begin{center}\small
<% set sep = joiner(" \\,\\textbullet\\, ") %>
<% if cv.personal.phone %><< sep() >><< cv.personal.phone >><% endif %>
<% if cv.personal.linkedin %><< sep() >>\href{https://<< cv.personal.linkedin >>}{<< link_text(cv.personal.linkedin, 'LinkedIn') >>}<% endif %>
<% if cv.personal.github %><< sep() >>\href{https://<< cv.personal.github >>}{<< link_text(cv.personal.github, 'GitHub') >>}<% endif %>
<% if cv.personal.website %><< sep() >>\href{https://<< cv.personal.website >>}{<< cv.personal.website >>}<% endif %>
<% if cv.personal.orcid %><< sep() >>ORCID: << cv.personal.orcid >><% endif %>
<% if cv.personal.scholar %><< sep() >>\href{https://<< cv.personal.scholar >>}{Scholar}<% endif %>
\end{center}

\vspace{4pt}

% =========================
% Sections
% =========================
<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\section{<< section_titles.get(key, 'prologue') >>}
\begin{center}
\begin{minipage}{0.86\linewidth}
\itshape << cv.summary >>
\end{minipage}
\end{center}
<% endif %>

<% if key == 'experience' and cv.experience %>
\section{<< section_titles.get(key, 'appointments') >>}
<% for job in cv.experience %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
{<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}}, \cvorg{<< job.company >>}<% if job.location %>, << job.location >><% endif %>.
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
\end{minipage}\par
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{<< section_titles.get(key, 'education') >>}
<% for edu in cv.education %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
{<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}}, \cvorg{<< edu.institution >>}.
<% if edu.gpa %> {\small GPA: << edu.gpa >>}<% endif %>
<% if edu.details %>\\{\small\itshape << edu.details >>}<% endif %>
\end{minipage}\par
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{<< section_titles.get(key, 'published works') >>}
\begin{enumerate}[leftmargin=1.6em,itemsep=3pt,topsep=\cvitembefore,label=\textup{\Roman*.}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{``<< pub.title >>''}<% else %>``<< pub.title >>''<% endif %><% if pub.authors %>, by << pub.authors | join(", ") >><% endif %><% if pub.venue %>. \cvorg{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{enumerate}
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{<< section_titles.get(key, 'works \& projects') >>}
<% for proj in cv.projects %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<% if proj.date %><< proj.date >><% else %>--<% endif %>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}} --- \cvorg{<< proj.description >>}.
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
\end{minipage}\par
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{<< section_titles.get(key, 'competencies') >>}
\begin{tabular}{@{}>{\raggedleft\arraybackslash}p{0.20\linewidth}@{\hspace{10pt}}p{0.76\linewidth}@{}}
<% for group in cv.skills %>
{\scshape << group.category >>} & << group.items | join(", ") >> \\[2pt]
<% endfor %>
\end{tabular}
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{<< section_titles.get(key, 'honours \& distinctions') >>}
<% for award in cv.awards %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<% if award.date %><< award.date >><% else %>--<% endif %>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
\cvrole{<< award.name >>}<% if award.issuer %>, \cvorg{<< award.issuer >>}<% endif %>.
<% if award.description %>\\{\small << award.description >>}<% endif %>
\end{minipage}\par
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{<< section_titles.get(key, 'certifications') >>}
<% for cert in cv.certifications %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<% if cert.date %><< cert.date >><% else %>--<% endif %>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
\cvrole{<< cert.name >>}<% if cert.issuer %>, \cvorg{<< cert.issuer >>}<% endif %>.
\end{minipage}\par
<% endfor %>
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{<< section_titles.get(key, 'languages') >>}
\begin{center}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~\cvorg{<< lang.proficiency >>}<% if not loop.last %>\quad\textbullet\quad <% endif %><% endfor %>
\end{center}
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{<< section_titles.get(key, 'civic \& other interests') >>}
<% for act in cv.extracurricular %>
\noindent\begin{minipage}[t]{0.18\linewidth}\raggedright
\cvdate{<% if act.date %><< act.date >><% else %>--<% endif %>}
\end{minipage}\hfill
\begin{minipage}[t]{0.80\linewidth}
\cvrole{<< act.title >>}<% if act.organization %>, \cvorg{<< act.organization >>}<% endif %>.
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
\end{minipage}\par
<% if not loop.last %>\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title | lower >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\vspace{6pt}
\noindent{\color{cvrule}\rule{\linewidth}{0.4pt}}\\[1pt]
\noindent{\color{cvrule}\rule{\linewidth}{1.6pt}}

\end{document}

% =============================================================
% MKCV — Template: signature-split
% Audience: creative directors, brand strategists, art leads
% Compiler: pdfLaTeX
% Layout: asymmetric header — name fills 2/3 in massive sans,
%         contact block in 1/3 tinted card; italic kickers above
%         each role like editorial pull-quotes
% =============================================================
\documentclass[<< font_size >>,a4paper]{article}
<< layout_preamble >>

\usepackage[a4paper,top=16mm,bottom=16mm,left=20mm,right=20mm]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{libertine}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{microtype}
<< xelatex_preamble >>
\usepackage{array}
\usepackage{parskip}
\usepackage{etoolbox}

% ---------- palette: ink + aubergine + tinted card -----------
\definecolor{cvink}{HTML}{151016}
\definecolor{cvmute}{HTML}{6E6770}
\definecolor{cvaccent}{HTML}{5B2A56}
\definecolor{cvcard}{HTML}{F0EAEF}
\definecolor{cvrule}{HTML}{D9D2DA}

\color{cvink}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3pt}
\pagestyle{empty}
\linespread{1.10}

% ---------- section heading: thin sans, oversized number -----
\titleformat{\section}
  {\normalsize\bfseries\sffamily\color{cvaccent}}
  {}{0em}
  {\MakeUppercase}
  [\vspace{1pt}{\color{cvaccent}\rule{1.6em}{1.4pt}}]
\titlespacing*{\section}{0pt}{\cvsecbefore}{\cvsecafter}

% ---------- helpers ------------------------------------------
\newcommand{\cvrole}[1]{{\bfseries\sffamily #1}}
\newcommand{\cvorg}[1]{{\itshape\color{cvmute} #1}}
\newcommand{\cvdate}[1]{{\sffamily\footnotesize\color{cvaccent} #1}}
\newcommand{\cvkicker}[1]{{\itshape\color{cvaccent} ``#1''}}

\newenvironment{cvitems}
  {\begin{itemize}[leftmargin=1.0em,labelsep=0.45em,itemsep=1.5pt,topsep=\cvitembefore,parsep=0pt,
                   label={\color{cvaccent}\rule[0.5ex]{0.5em}{1.2pt}}]}
  {\end{itemize}}

\begin{document}

% =========================
% Header — split asymmetric
% =========================
\noindent
\begin{minipage}[t]{0.62\linewidth}
\vspace{0pt}
{\sffamily\fontseries{l}\selectfont<< cv.personal.name | name_fontsize(46, 0.95) >>%
\color{cvink}<< cv.personal.name.split()[0] if cv.personal.name.split()|length > 1 else cv.personal.name >>}\\[-2pt]
<% if cv.personal.name.split()|length > 1 %>
{\sffamily\bfseries<< cv.personal.name | name_fontsize(46, 0.95) >>%
\color{cvaccent}<< cv.personal.name.split()[1:] | join(' ') >>}
<% endif %>
<% if cv.personal.tagline %>
\\[6pt]{\sffamily\large\itshape\color{cvmute} << cv.personal.tagline >>}
<% endif %>
\end{minipage}\hfill
\begin{minipage}[t]{0.34\linewidth}
\vspace{2pt}
\colorbox{cvcard}{%
  \begin{minipage}[t]{\dimexpr\linewidth-12pt\relax}
  \vspace{4pt}
  {\sffamily\scriptsize\bfseries\color{cvaccent}\MakeUppercase{Contact}}\\[3pt]
  {\sffamily\footnotesize\color{cvink}%
  <% if cv.personal.email and contact_visible('email') %>\href{mailto:<< cv.personal.email >>}{<< cv.personal.email >>}\\[1.5pt]<% endif %>
  <% if cv.personal.phone and contact_visible('phone') %><< cv.personal.phone >>\\[1.5pt]<% endif %>
  <% if cv.personal.location and contact_visible('location') %><< cv.personal.location >>\\[1.5pt]<% endif %>
  <% if cv.personal.website and contact_visible('website') %>\href{https://<< cv.personal.website >>}{<< link_text(cv.personal.website, 'Website', contact_link_style('website')) >>}\\[1.5pt]<% endif %>
  <% if cv.personal.linkedin and contact_visible('linkedin') %>\href{https://<< cv.personal.linkedin >>}{<< link_text(cv.personal.linkedin, 'LinkedIn', contact_link_style('linkedin')) >>}\\[1.5pt]<% endif %>
  <% if cv.personal.github and contact_visible('github') %>\href{https://<< cv.personal.github >>}{<< link_text(cv.personal.github, 'GitHub', contact_link_style('github')) >>}\\[1.5pt]<% endif %>
  <% if cv.personal.huggingface and contact_visible('huggingface') %>\href{https://<< cv.personal.huggingface >>}{<< link_text(cv.personal.huggingface, 'Hugging Face', contact_link_style('huggingface')) >>}\\[1.5pt]<% endif %>
  }
  \vspace{2pt}
  \end{minipage}%
}
\end{minipage}

\vspace{10pt}

% =========================
% Sections
% =========================
<% macro render_section(key) %>
<% if key == 'summary' and cv.summary %>
\section{<< section_titles.get(key, 'Statement') >>}
{\large\itshape\color{cvink} << cv.summary >>}
<% endif %>

<% if key == 'experience' and cv.experience %>
\section{<< section_titles.get(key, 'Experience') >>}
<% for job in cv.experience %>
{<< job.title | shrink_if_long(48) >>\cvrole{<< job.title >>}} \hfill \cvdate{<< job.start_date >> -- << job.end_date if job.end_date else "Present" >>}\\
\cvorg{<< job.company >>}<% if job.location %> \,/\, {\footnotesize\color{cvmute}<< job.location >>}<% endif %>
<% if job.description %>\\\cvkicker{<< job.description >>}<% endif %>
<% if job.highlights %>
\begin{cvitems}
<% for item in job.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\par\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'education' and cv.education %>
\section{<< section_titles.get(key, 'Education') >>}
<% for edu in cv.education %>
{<< edu.degree | shrink_if_long(48) >>\cvrole{<< edu.degree >>}} \hfill \cvdate{<% if edu.year %><< edu.year >><% elif edu.start_date %><< edu.start_date >> -- << edu.end_date if edu.end_date else "Present" >><% endif %>}\\
\cvorg{<< edu.institution >>}<% if edu.gpa %> \,/\, {\footnotesize GPA: << edu.gpa >>}<% endif %>
<% if edu.details %>\\{\footnotesize\itshape << edu.details >>}<% endif %>
<% if not loop.last %>\par\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'skills' and cv.skills %>
\section{<< section_titles.get(key, 'Skills') >>}
\begin{tabular}{@{}p{0.22\linewidth}@{\hspace{6pt}}p{0.74\linewidth}@{}}
<% for group in cv.skills %>
{\sffamily\bfseries\color{cvaccent}<< group.category >>} & << group.items | join(", ") >> \\[2pt]
<% endfor %>
\end{tabular}
<% endif %>

<% if key == 'projects' and cv.projects %>
\section{<< section_titles.get(key, 'Selected Work') >>}
<% for proj in cv.projects %>
{<< proj.name | shrink_if_long(40) >>\cvrole{<% if proj.url %>\href{https://<< proj.url >>}{<< proj.name >>}<% else %><< proj.name >><% endif %>}}<% if proj.date %> \hfill \cvdate{<< proj.date >>}<% endif %>\\
\cvorg{<< proj.description >>}
<% if proj.highlights %>
\begin{cvitems}
<% for item in proj.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\par\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'publications' and cv.publications %>
\section{<< section_titles.get(key, 'Press \& Publications') >>}
\begin{itemize}[leftmargin=1.2em,itemsep=3pt,topsep=\cvitembefore,label={\color{cvaccent}\textbullet}]
<% for pub in cv.publications %>
  \item <% if pub.url %>\href{https://<< pub.url >>}{\textit{<< pub.title >>}}<% else %>\textit{<< pub.title >>}<% endif %><% if pub.authors %>. << pub.authors | join(", ") >><% endif %><% if pub.venue %>. \cvorg{<< pub.venue >>}<% endif %><% if pub.date %>, << pub.date >><% endif %>.
<% endfor %>
\end{itemize}
<% endif %>

<% if key == 'awards' and cv.awards %>
\section{<< section_titles.get(key, 'Recognition') >>}
<% for award in cv.awards %>
\cvrole{<< award.name >>}<% if award.issuer %> --- \cvorg{<< award.issuer >>}<% endif %><% if award.date %> \hfill \cvdate{<< award.date >>}<% endif %>\\
<% if award.description %>{\footnotesize << award.description >>}\\<% endif %>
<% if not loop.last %>\par\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key == 'certifications' and cv.certifications %>
\section{<< section_titles.get(key, 'Certifications') >>}
<% for cert in cv.certifications %>
\cvrole{<< cert.name >>}<% if cert.issuer %> --- \cvorg{<< cert.issuer >>}<% endif %><% if cert.date %> \hfill \cvdate{<< cert.date >>}<% endif %>\\
<% endfor %>
<% endif %>

<% if key == 'languages' and cv.languages %>
\section{<< section_titles.get(key, 'Languages') >>}
<% for lang in cv.languages %>\cvrole{<< lang.language >>}~--~\cvorg{<< lang.proficiency >>}<% if not loop.last %>\quad\textbullet\quad <% endif %><% endfor %>
<% endif %>

<% if key == 'extracurricular' and cv.extracurricular %>
\section{<< section_titles.get(key, 'Beyond Studio') >>}
<% for act in cv.extracurricular %>
\cvrole{<< act.title >>}<% if act.organization %> --- \cvorg{<< act.organization >>}<% endif %><% if act.date %> \hfill \cvdate{<< act.date >>}<% endif %>\\
<% if act.highlights %>
\begin{cvitems}
<% for item in act.highlights %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% endif %>
<% if not loop.last %>\par\vspace{\cvvgap}<% endif %>
<% endfor %>
<% endif %>

<% if key in custom_by_key %>
<% set cs = custom_by_key[key] %>
\section{<< cs.title >>}
<% for block in cs.content %>
<% set extras = block.model_extra %>
<% if block.type == 'text' %>
<< extras.get('value', '') >>
<% elif block.type == 'bullets' %>
\begin{cvitems}
<% for item in extras.get('items', []) %>
    \item << item >>
<% endfor %>
\end{cvitems}
<% elif block.type == 'kv' %>
\begin{tabular}{@{}p{3cm}l@{}}
<% for pair in extras.get('pairs', []) %>
\cvrole{<< pair.key >>} & \cvorg{<< pair.value >>} \\
<% endfor %>
\end{tabular}
<% endif %>
<% endfor %>
<% endif %>
<% endmacro %>

<% for key in section_order %>
<< render_section(key) >>
<% endfor %>

\end{document}
